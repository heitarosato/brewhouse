---
// Formspree form ID — replace XXXXXXXX with your actual Formspree form ID after signup
const FORMSPREE_ID = 'xaqlybrq';
---
<div class="section-divider"></div>
<section id="contact">
  <div class="container">
    <p class="section-tag">CONTACT</p>
    <p class="contact-lead">
      ご相談、サービスに関するお問い合わせなど、お気軽にご連絡ください。<br>
      まずはオンラインでのカジュアル面談も歓迎しています。
    </p>
    <form
      action={`https://formspree.io/f/${FORMSPREE_ID}`}
      method="POST"
      class="contact-form"
    >
      <div class="form-row two-col">
        <div class="form-field">
          <label for="name">お名前</label>
          <input type="text" id="name" name="name" required autocomplete="name" />
        </div>
        <div class="form-field">
          <label for="company">会社名</label>
          <input type="text" id="company" name="company" autocomplete="organization" />
        </div>
      </div>
      <div class="form-field">
        <label for="email">メールアドレス</label>
        <input type="email" id="email" name="email" required autocomplete="email" />
      </div>
      <div class="form-field">
        <label for="message">ご相談内容</label>
        <textarea id="message" name="message" rows="6" required></textarea>
      </div>
      <button type="submit" class="submit-btn">送 信</button>
    </form>
  </div>
</section>

<style>
  .contact-lead {
    font-size: 13px;
    font-weight: 300;
    color: #5a7a60;
    line-height: 2.0;
    margin-bottom: 52px;
  }
  .contact-form {
    max-width: 680px;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }
  .form-row.two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }
  .form-field {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  label {
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 0.1em;
    color: #9ab09a;
  }
  input,
  textarea {
    border: none;
    border-bottom: 1px solid #d8e8d8;
    background: transparent;
    font-family: 'Noto Sans JP', sans-serif;
    font-size: 13px;
    font-weight: 300;
    color: #1a3020;
    padding: 10px 0;
    outline: none;
    transition: border-color 0.2s;
    resize: vertical;
    width: 100%;
  }
  input:focus,
  textarea:focus {
    border-color: #2d6640;
  }
  .submit-btn {
    display: inline-block;
    padding: 14px 40px;
    border: 1px solid #2d6640;
    background: transparent;
    color: #2d6640;
    font-family: 'Noto Sans JP', sans-serif;
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 0.3em;
    cursor: pointer;
    transition: background 0.3s, color 0.3s;
    align-self: flex-start;
  }
  .submit-btn:hover {
    background: #2d6640;
    color: #ffffff;
  }
  @media (max-width: 768px) {
    .form-row.two-col {
      grid-template-columns: 1fr;
    }
  }
</style>
