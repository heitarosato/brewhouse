---
---
<footer>
  <div class="container">
    <div class="footer-inner">
      <span class="footer-logo">brewhouse</span>
      <span class="footer-copy">© 2025 brewhouse. All rights reserved.</span>
    </div>
  </div>
</footer>

<style>
  footer {
    background: #1a3020;
    padding: 40px 0;
  }
  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .footer-logo {
    font-family: 'Noto Serif JP', serif;
    font-weight: 200;
    font-size: 14px;
    letter-spacing: 0.35em;
    color: #ffffff;
  }
  .footer-copy {
    font-family: 'Noto Sans JP', sans-serif;
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 0.05em;
    color: rgba(255,255,255,0.4);
  }
  @media (max-width: 768px) {
    .footer-inner {
      flex-direction: column;
      gap: 16px;
      text-align: center;
    }
  }
</style>
