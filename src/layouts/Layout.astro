---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'brewhouse — 食・ホスピタリティ領域のコンサルティング',
  description = '外食チェーンをはじめ、食・ホスピタリティ業界に特化したコンサルティング会社。外食の成長戦略・M&A・海外進出・業態・出店モデル改革など幅広い経営課題を、戦略コンサル・外食企業経験者が直接ハンズオンでご支援します。',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>

  <!-- OGP -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://brewhouse.co.jp" />
  <meta property="og:locale" content="ja_JP" />

  <!-- Canonical -->
  <link rel="canonical" href="https://brewhouse.co.jp" />

  <!-- JSON-LD -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "name": "brewhouse",
    "url": "https://brewhouse.co.jp",
    "description": "外食チェーンをはじめ、食・ホスピタリティ業界に特化したコンサルティング会社。成長戦略・M&A・海外進出・業態・出店モデル改革を支援。",
    "founder": { "@type": "Person", "name": "佐藤 平太郎" },
    "knowsAbout": ["外食", "食品", "M&A", "海外進出", "成長戦略", "業態・出店モデル改革", "ホスピタリティ"],
    "areaServed": "JP",
    "inLanguage": "ja"
  }
  </script>

  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-YNGE8X5XFJ"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-YNGE8X5XFJ');
  </script>

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Preconnect for Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
</head>
<body>
  <slot />
</body>
</html>
